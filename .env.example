# Copie este arquivo para .env e preencha com os tokens reais.
# .env é ignorado pelo git (ver .gitignore).

# Kommo CRM
KOMMO_SUBDOMAIN=ipiocamarresort
KOMMO_TOKEN=<kommo-long-lived-token>

# Meta Ads (Graph API)
META_TOKEN=<meta-access-token>
META_ACCOUNT=act_XXXXXXXXXXX

# Google Ads (OAuth2)
GOOGLE_ADS_DEVELOPER_TOKEN=<developer-token>
GOOGLE_ADS_CLIENT_ID=<oauth-client-id>.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-<secret>
GOOGLE_ADS_CUSTOMER_ID=<10-digit-customer-id>
GOOGLE_ADS_LOGIN_CUSTOMER_ID=<10-digit-mcc-id-se-aplicavel>
